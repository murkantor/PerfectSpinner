<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PerfectSpinner.ViewModels"
        xmlns:views="using:PerfectSpinner.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PerfectSpinner.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="940" d:DesignHeight="830"
        Icon="/Assets/avalonia-logo.ico"
        Title="PerfectSpinner — Settings"
        MinWidth="640" MinHeight="480"
        Width="940" Height="830">

    <DockPanel Margin="12">

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="PerfectSpinner" FontSize="20" FontWeight="Bold" />
                <TextBlock Text=" - By Murk17" FontSize="15" FontStyle="Italic"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Bottom" Margin="4,0,0,1" Padding="0,0,6,0" />
            </StackPanel>
            <Separator />
        </StackPanel>

        <!-- ── Custom scrollable tab bar ───────────────────────────────── -->
        <!--
            Layout: [◀]  [scrollable list of wheel tabs]  [▶]  [+]
            The ListBox uses a horizontal StackPanel as its items panel.
            The outer ScrollViewer hides the scrollbar; ◀ / ▶ buttons scroll it.
        -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="Auto,*,Auto,Auto"
              Margin="0,0,0,4">

            <Button Grid.Column="0" Content="◀" Click="OnScrollLeft"
                    Padding="6,4" VerticalAlignment="Stretch"
                    ToolTip.Tip="Previous wheel" />

            <ScrollViewer Grid.Column="1" x:Name="TabScroller"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <ListBox x:Name="TabList"
                         ItemsSource="{Binding Wheels}"
                         SelectedIndex="{Binding ActiveWheelIndex, Mode=TwoWay}"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:WheelViewModel">
                            <Panel MinWidth="70" Margin="2,0">
                                <Panel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Rename" Click="OnTabRenameClick" />
                                        <MenuItem Header="Clone"  Click="OnTabCloneClick"  />
                                        <Separator />
                                        <MenuItem Header="Delete" Click="OnTabDeleteClick" />
                                    </ContextMenu>
                                </Panel.ContextMenu>
                                <!-- Display: double-click (handled in code-behind) starts rename -->
                                <TextBlock Text="{Binding Name}"
                                           IsVisible="{Binding !IsEditingName}"
                                           VerticalAlignment="Center" />
                                <!-- Edit: visible while renaming -->
                                <TextBox Text="{Binding Name}"
                                         IsVisible="{Binding IsEditingName}"
                                         MinWidth="80" Padding="2,0" />
                            </Panel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <Button Grid.Column="2" Content="▶" Click="OnScrollRight"
                    Padding="6,4" VerticalAlignment="Stretch"
                    ToolTip.Tip="Next wheel" />

            <Button Grid.Column="3" Content="+" Command="{Binding AddWheelCommand}"
                    ToolTip.Tip="Add new wheel"
                    Padding="8,4" Margin="6,0,0,0" VerticalAlignment="Stretch" />

        </Grid>

        <!-- ── Spin All ─────────────────────────────────────────────────── -->
        <Button DockPanel.Dock="Top"
                Content="🎡  Spin All Wheels"
                Command="{Binding SpinAllCommand}"
                HorizontalAlignment="Stretch"
                FontSize="15" FontWeight="SemiBold"
                Padding="0,8" Margin="0,0,0,6"
                ToolTip.Tip="Spin every wheel tab simultaneously" />

        <!-- ── Active wheel editor ──────────────────────────────────────── -->
        <ContentControl Content="{Binding ActiveWheel}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:WheelViewModel">
                    <views:WheelEditorPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

    </DockPanel>

</Window>
