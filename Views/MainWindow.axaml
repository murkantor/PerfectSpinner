<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GoldenSpinner.ViewModels"
        xmlns:views="using:GoldenSpinner.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="GoldenSpinner.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="940" d:DesignHeight="830"
        Icon="/Assets/avalonia-logo.ico"
        Title="SpinnerWheel — Settings"
        MinWidth="640" MinHeight="480"
        Width="940" Height="830">

    <DockPanel Margin="12">

        <!-- ── Header (always visible) ───────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,8">
            <TextBlock Text="SpinnerWheel" FontSize="20" FontWeight="Bold" />
            <Separator />
        </StackPanel>

        <!-- ── Tab control — one tab per wheel ───────────────────────── -->
        <!--
            ItemsSource drives both tabs from the Wheels list.
            ContentTemplate sets DataContext = WheelViewModel for each tab,
            which WheelEditorPanel consumes via its own x:DataType binding context.
            SelectedIndex syncs with ActiveWheelIndex so the SpinnerWindow follows.
        -->
        <TabControl ItemsSource="{Binding Wheels}"
                    SelectedIndex="{Binding ActiveWheelIndex}">

            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="vm:WheelViewModel">
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate x:DataType="vm:WheelViewModel">
                    <views:WheelEditorPanel />
                </DataTemplate>
            </TabControl.ContentTemplate>

        </TabControl>

    </DockPanel>

</Window>
