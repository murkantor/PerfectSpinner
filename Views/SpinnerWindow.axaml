<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PerfectSpinner.ViewModels"
        xmlns:controls="using:PerfectSpinner.Controls"
        x:Class="PerfectSpinner.Views.SpinnerWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PerfectSpinner — OBS Capture"
        Width="830" Height="830"
        MinWidth="300" MinHeight="300"
        Background="{Binding ActiveWheel.ChromaKeyColor, Converter={StaticResource HexColorToBrush}}">

    <!--
        ════════════════════════════════════════════════════════════════
        OBS CAPTURE WINDOW
        ════════════════════════════════════════════════════════════════
        • Add this window as a "Window Capture" source in OBS.
        • Apply a Chroma Key filter using the colour set in Settings.
        • Switching tabs in the Settings window switches which wheel is
          displayed here — making per-wheel OBS scenes easy to set up.
        ════════════════════════════════════════════════════════════════
    -->

    <Grid>

        <!-- Wheel fills the entire window; Viewbox scales it uniformly -->
        <Viewbox Stretch="Uniform">
            <controls:PerfectSpinnerControl
                Width="600" Height="600"
                Slices="{Binding ActiveWheel.Slices}"
                RotationAngle="{Binding ActiveWheel.CurrentRotation}"
                WinnerIndex="{Binding ActiveWheel.WinnerIndex}"
                UseWeightedSlices="{Binding ActiveWheel.UseWeightedSlices}"
                SliceImageMode="{Binding ActiveWheel.SliceImageMode}"
                ShowLabels="{Binding ActiveWheel.ShowLabels}"
                ShowPointerLabel="{Binding ActiveWheel.ShowPointerLabel}"
                LabelFontFamily="{Binding ActiveWheel.LabelFontFamily}"
                LabelFontSize="{Binding ActiveWheel.LabelFontSize}"
                LabelColorStyle="{Binding ActiveWheel.LabelColorStyle}"
                LabelBold="{Binding ActiveWheel.LabelBold}"
                BrightenWinner="{Binding ActiveWheel.BrightenWinner}"
                DarkenLosers="{Binding ActiveWheel.DarkenLosers}"
                InvertLoserText="{Binding ActiveWheel.InvertLoserText}"
                BorderColorStyle="{Binding ActiveWheel.BorderColorStyle}"
                BlackoutWheelMode="{Binding ActiveWheel.BlackoutWheelMode}"
                ShowConfetti="{Binding ActiveWheel.ShowConfetti}"
                ConfettiImagePath="{Binding ActiveWheel.ConfettiImagePath}"
                ConfettiCount="{Binding ActiveWheel.ConfettiCount}"
                ConfettiShapeMode="{Binding ActiveWheel.ConfettiShapeMode}"
                ConfettiColorMode="{Binding ActiveWheel.ConfettiColorMode}"
                ConfettiCustomColor="{Binding ActiveWheel.ConfettiCustomColor}"
                CapTo30Fps="{Binding ActiveWheel.CapTo30Fps}"
                PointerOnRight="{Binding ActiveWheel.PointerOnRight}" />
        </Viewbox>

        <!-- Winner banner -->
        <Border VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Background="#CC000000"
                CornerRadius="8"
                Padding="24,10"
                IsVisible="{Binding ActiveWheel.WinnerMessage,
                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ActiveWheel.WinnerMessage}"
                       FontSize="30" FontWeight="Bold"
                       Foreground="White" />
        </Border>

    </Grid>
</Window>
